{
  "name": "@molen/api",
  "version": "0.1.0",
  "description": "Bun-powered ElysiaJS backend for Fraud-Ops Control Plane",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --external mock-aws-s3 --external aws-sdk --external nock",
    "typecheck": "tsc --noEmit",
    "start": "bun run src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "elysia": "^0.8.14",
    "@elysiajs/cors": "^0.8.0",
    "@elysiajs/jwt": "^0.8.0",
    "@elysiajs/bearer": "^0.8.0",
    "@molen/core": "workspace:*",
    "postgres": "^3.4.3",
    "nanoid": "^5.0.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.3.3"
  }
}
