# API Configuration
PORT=3000
SHADOW_MODE=false

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/molen

# Authentication & Sessions
SESSION_TTL=86400
SESSION_SECRET=change-this-to-a-secure-random-string
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict

# OAuth2 Provider Configuration (optional)
OAUTH2_ENABLED=false
OAUTH2_PROVIDER=keycloak
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_AUTHORIZATION_URL=
OAUTH2_TOKEN_URL=
OAUTH2_USERINFO_URL=
OAUTH2_REDIRECT_URI=http://localhost:3000/auth/oauth2/callback
OAUTH2_SCOPES=openid,profile,email

# Kafka Broker (Kafka-compatible API - works with Kafka, Redpanda, etc.)
KAFKA_BROKERS=localhost:9092
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SASL_MECHANISM=scram-sha-256

# Kafka Connect (Pipeline processing - compatible with Kafka Connect and Redpanda Connect)
KAFKA_CONNECT_URL=http://localhost:4195
KAFKA_CONNECT_API_KEY=

# External Services
ELASTIC_URL=https://elasticsearch:9200
ELASTIC_USERNAME=
ELASTIC_PASSWORD=

REDIS_URL=redis://localhost:6379
# Alternative Redis config (if not using URL)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# S3-Compatible Storage for ML Models (works with AWS S3, Cloudflare R2, MinIO, Garage, etc.)
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=ml-models
S3_REGION=auto

# Security (REQ-2.3, NFR-1.2)
# CA_CERT_PATH=/path/to/homelab-ca.crt

# Testing - Set to true to use mock implementations
USE_MOCKS=true
