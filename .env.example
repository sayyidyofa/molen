# ==========================================
# PROJECT MOLEN: ENVIRONMENT CONFIGURATION
# ==========================================

# --- Environment ---
NODE_ENV=development
RUST_LOG=info

# --- Database (PostgreSQL) ---
# Stores UI state, Orchestrator definitions, and Schema metadata
POSTGRES_USER=molen_admin
POSTGRES_PASSWORD=molen_local_secret
POSTGRES_DB=molen_db
DATABASE_URL="postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}"

# --- Event Stream (Redpanda/Kafka) ---
# Comma-separated list of brokers
KAFKA_BROKERS=localhost:19092
SEED_KAFKA=true
# Topics
MOLEN_CONTROL_TOPIC=molen_control_dev
MOLEN_INBOUND_TOPIC=molen_transactions_in
MOLEN_OUTBOUND_TOPIC=molen_scores_out

# --- Object Storage (S3 / MinIO) ---
# For storing and retrieving .onnx ML models
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=molen_minio_admin
S3_SECRET_KEY=molen_minio_secret
S3_BUCKET_MODELS=molen-models-dev

# --- API Configuration ---
API_PORT=3000
API_HOST=0.0.0.0