# API Configuration
PORT=3000
SHADOW_MODE=false

# Redpanda (Message Broker - replaces LavinMQ)
REDPANDA_BROKER_URL=localhost:9092
REDPANDA_CONNECT_URL=http://localhost:4195
REDPANDA_CONNECT_API_KEY=

# Redpanda Broker (Kafka API) - for direct message streaming
REDPANDA_BROKERS=localhost:9092
REDPANDA_USERNAME=
REDPANDA_PASSWORD=
REDPANDA_SASL_MECHANISM=scram-sha-256

# External Services
ELASTIC_URL=https://elasticsearch:9200
ELASTIC_USERNAME=
ELASTIC_PASSWORD=

REDIS_URL=redis://localhost:6379
# Alternative Redis config (if not using URL)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Legacy Flink (being phased out - replaced by Redpanda Connect)
FLINK_URL=http://localhost:8081
# Optional Cloudflare Access headers for Flink
FLINK_CLIENT_ID=
FLINK_CLIENT_SECRET=

# S3-Compatible Storage for ML Models (Cloudflare R2 or Garage)
S3_ENDPOINT=https://08ebc404f616b60b048d5dbbe34af11a.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=ml-models
S3_REGION=auto

# Garage S3 for Training Data (alternative to Cloudflare R2)
GARAGE_ENDPOINT=
GARAGE_ACCESS_KEY_ID=
GARAGE_SECRET_ACCESS_KEY=
GARAGE_TRAINING_BUCKET=training-data

# Security (REQ-2.3, NFR-1.2)
# CA_CERT_PATH=/path/to/homelab-ca.crt

# Testing - Set to true to use mock implementations
USE_MOCKS=true
