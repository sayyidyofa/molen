# API Configuration
PORT=3000
SHADOW_MODE=false

# External Services
ELASTIC_URL=https://elasticsearch:9200
ELASTIC_USERNAME=
ELASTIC_PASSWORD=

REDIS_URL=redis://localhost:6379
# Alternative Redis config (if not using URL)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

FLINK_URL=http://localhost:8081
# Optional Cloudflare Access headers for Flink
FLINK_CLIENT_ID=
FLINK_CLIENT_SECRET=

# S3-Compatible Storage (Cloudflare R2 or AWS S3) for ML Model Storage
S3_ENDPOINT=https://08ebc404f616b60b048d5dbbe34af11a.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=ml-models
S3_REGION=auto

# Security (REQ-2.3, NFR-1.2)
# CA_CERT_PATH=/path/to/homelab-ca.crt

# Testing - Set to true to use mock implementations
USE_MOCKS=true
