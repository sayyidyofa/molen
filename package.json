{
  "name": "molen",
  "version": "0.1.0",
  "private": true,
  "description": "Fraud-Ops Control Plane - High-performance fraud detection orchestration system",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun run --cwd packages/api dev",
    "dev:ui": "bun run --cwd packages/ui dev",
    "build": "bun run build:core && bun run build:api && bun run build:ui",
    "build:core": "bun run --cwd packages/core build",
    "build:api": "bun run --cwd packages/api build",
    "build:ui": "bun run --cwd packages/ui build",
    "typecheck": "bun run typecheck:core && bun run typecheck:api && bun run typecheck:ui",
    "typecheck:core": "bun run --cwd packages/core typecheck",
    "typecheck:api": "bun run --cwd packages/api typecheck",
    "typecheck:ui": "bun run --cwd packages/ui typecheck",
    "test": "bun test",
    "test:core": "bun test --cwd packages/core",
    "test:api": "bun test --cwd packages/api",
    "test:ui": "bun test --cwd packages/ui",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
